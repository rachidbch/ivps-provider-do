#!/bin/bash
set -e

# --- IVPS DigitalOcean Provider Plugin ---
# Implements the IVPS plugin interface for DigitalOcean.
# Credentials are received as env vars (auto-exported by ivps from config.env).
# Cloud-init templating and cleanup on failure are handled by ivps core.

# Exit code constants
EXIT_OK=0
EXIT_ERR=1
EXIT_AUTH=2
EXIT_NOTFOUND=3
EXIT_DEP=4

# Ensure DO_API_TOKEN is available
require_token() {
    if [ -z "$DO_API_TOKEN" ]; then
        echo "[ERROR] DO_API_TOKEN not set. Run: ivps node setup digitalocean" >&2
        exit "$EXIT_AUTH"
    fi
}

# Ensure doctl is installed
require_doctl() {
    if ! command -v doctl &>/dev/null; then
        echo "[ERROR] doctl is not installed. Install: https://docs.digitalocean.com/reference/doctl/how-to/install/" >&2
        exit "$EXIT_DEP"
    fi
}

# --- SUBCOMMANDS ---

cmd_keys() {
    echo "DO_API_TOKEN:DigitalOcean API Token"
}

cmd_validate() {
    require_token
    require_doctl
    local response
    response=$(doctl account get -t "$DO_API_TOKEN" -o json 2>/dev/null) || true
    local email
    email=$(echo "$response" | jq -r '.email // empty' 2>/dev/null)
    if [ -n "$email" ]; then
        echo "Authenticated: $email"
        return 0
    else
        local msg
        msg=$(echo "$response" | jq -r '.message // empty' 2>/dev/null)
        echo "[ERROR] Failed to authenticate with DigitalOcean API.${msg:+ $msg}" >&2
        exit "$EXIT_AUTH"
    fi
}

cmd_create() {
    require_token
    require_doctl

    local name=$1
    shift

    if [ -z "$name" ]; then
        echo "[ERROR] Usage: plugin create <name> [--plan ...] [--region ...] [--image ...] [--cloud-init <path>]" >&2
        exit "$EXIT_ERR"
    fi

    # Defaults
    local plan="s-2vcpu-4gb"
    local region="nyc1"
    local image="ubuntu-24-04-x64"
    local cloud_init_path=""

    # Parse options
    while [ $# -gt 0 ]; do
        case "$1" in
            --plan)       plan="$2";           shift 2 ;;
            --region)     region="$2";         shift 2 ;;
            --image)      image="$2";          shift 2 ;;
            --cloud-init) cloud_init_path="$2"; shift 2 ;;
            *)            shift ;;
        esac
    done

    echo "Creating droplet '$name' ($plan, $region, $image)..." >&2

    # Build doctl create args
    local create_args=(
        compute droplet create "$name"
        --size "$plan"
        --image "$image"
        --region "$region"
        --enable-ipv6
        --enable-monitoring
        --wait
        -t "$DO_API_TOKEN"
        -o json
    )
    if [ -n "$cloud_init_path" ] && [ -f "$cloud_init_path" ]; then
        create_args+=(--user-data-file "$cloud_init_path")
    fi

    local response
    response=$(doctl "${create_args[@]}" 2>/dev/null)

    # Check for errors â€” response must be a JSON array with a valid id
    local first_id
    first_id=$(echo "$response" | jq -r '.[0].id // empty' 2>/dev/null) || true

    if [ -z "$first_id" ]; then
        local err_msg
        err_msg=$(echo "$response" | jq -r '.message // empty' 2>/dev/null) || true
        echo "[ERROR] ${err_msg:-$(echo "$response" | head -1)}" >&2
        exit "$EXIT_ERR"
    fi

    local ipv4 ipv6
    ipv4=$(echo "$response" | jq -r '.[0].networks.v4[] | select(.type=="public") | .ip_address' 2>/dev/null | head -1) || true
    ipv6=$(echo "$response" | jq -r '.[0].networks.v6[] | select(.type=="public") | .ip_address' 2>/dev/null | head -1) || true

    if [ -z "$ipv4" ]; then
        echo "[ERROR] Droplet created but no IPv4 assigned." >&2
        exit "$EXIT_ERR"
    fi

    # Output contract for ivps
    echo "IPV4:$ipv4"
    echo "IPV6:${ipv6:-}"
    echo "PROVIDER_ID:$(echo "$response" | jq -r '.[0].id')"
    echo "METADATA:plan=$plan"
    echo "METADATA:region=$region"
    echo "METADATA:image=$image"
}

cmd_delete() {
    require_token
    require_doctl

    local name=$1
    if [ -z "$name" ]; then
        echo "[ERROR] Usage: plugin delete <name>" >&2
        exit "$EXIT_ERR"
    fi

    # Look up droplet by name via doctl
    local response
    response=$(doctl compute droplet get "$name" -t "$DO_API_TOKEN" -o json 2>/dev/null) || true

    local droplet_id
    droplet_id=$(echo "$response" | jq -r '.id // empty' 2>/dev/null)

    if [ -z "$droplet_id" ]; then
        echo "[ERROR] Droplet '$name' not found." >&2
        exit "$EXIT_NOTFOUND"
    fi

    echo "Destroying droplet $droplet_id ($name)..." >&2
    doctl compute droplet delete "$name" -f -t "$DO_API_TOKEN" &>/dev/null
    echo "Droplet destroyed." >&2
}

cmd_list() {
    require_token
    require_doctl

    local droplets
    droplets=$(doctl compute droplet list -t "$DO_API_TOKEN" -o json 2>/dev/null)
    echo "$droplets" | jq -r '.[] | "\(.id)\t\(.name)\t\(.networks.v4[] | select(.type=="public") | .ip_address)\t\(.size.slug)\t\(.region.slug)\t\(.status)"' 2>/dev/null | \
        column -t -s $'\t' -N "ID,NAME,IPV4,PLAN,REGION,STATUS"
}

cmd_show() {
    require_token
    require_doctl

    local name=$1
    if [ -z "$name" ]; then
        echo "[ERROR] Usage: plugin show <name>" >&2
        exit "$EXIT_ERR"
    fi

    local response
    response=$(doctl compute droplet get "$name" -t "$DO_API_TOKEN" -o json 2>/dev/null) || true

    # Check if we got valid JSON with an id field
    local droplet_id
    droplet_id=$(echo "$response" | jq -r '.id // empty' 2>/dev/null)

    if [ -z "$droplet_id" ]; then
        echo "[ERROR] Droplet '$name' not found." >&2
        exit "$EXIT_NOTFOUND"
    fi

    echo "$response" | jq '{
        id: .id,
        name: .name,
        status: .status,
        plan: .size.slug,
        region: .region.slug,
        ipv4: [.networks.v4[] | select(.type=="public") | .ip_address][0],
        ipv6: [.networks.v6[] | select(.type=="public") | .ip_address][0],
        image: .image.slug,
        created: .created_at
    }'
}

# --- DISPATCHER ---

case "${1:-}" in
    keys)     cmd_keys ;;
    validate) cmd_validate ;;
    create)   cmd_create "${@:2}" ;;
    delete)   cmd_delete "$2" ;;
    list)     cmd_list ;;
    show)     cmd_show "$2" ;;
    *)
        echo "Usage: plugin <keys|validate|create|delete|list|show> [args]"
        exit "$EXIT_ERR"
        ;;
esac
