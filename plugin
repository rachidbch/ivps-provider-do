#!/bin/bash
set -e

# --- IVPS DigitalOcean Provider Plugin ---
# Implements the IVPS plugin interface for DigitalOcean.
# Credentials are received as env vars (auto-exported by ivps from config.env).

# Ensure DO_API_TOKEN is available
require_token() {
    if [ -z "$DO_API_TOKEN" ]; then
        echo "[ERROR] DO_API_TOKEN not set. Run: ivps node setup digitalocean" >&2
        exit 2
    fi
}

# DigitalOcean API helper
do_api() {
    local method=$1
    local endpoint=$2
    local data=$3

    local args=(-s -H "Authorization: Bearer $DO_API_TOKEN" -H "Content-Type: application/json")

    if [ "$method" == "GET" ]; then
        curl "${args[@]}" "https://api.digitalocean.com/v2${endpoint}"
    elif [ "$method" == "DELETE" ]; then
        curl "${args[@]}" -X DELETE "https://api.digitalocean.com/v2${endpoint}"
    elif [ -n "$data" ]; then
        curl "${args[@]}" -X "$method" "https://api.digitalocean.com/v2${endpoint}" -d "$data"
    else
        curl "${args[@]}" -X "$method" "https://api.digitalocean.com/v2${endpoint}"
    fi
}

# --- SUBCOMMANDS ---

cmd_keys() {
    echo "DO_API_TOKEN:DigitalOcean API Token"
}

cmd_validate() {
    require_token
    local response
    response=$(do_api GET /regions 2>/dev/null)
    local region_count
    region_count=$(echo "$response" | jq '.regions | length' 2>/dev/null)
    if [ -n "$region_count" ] && [ "$region_count" -gt 0 ] 2>/dev/null; then
        echo "Authenticated: $region_count regions available"
        return 0
    else
        local msg
        msg=$(echo "$response" | jq -r '.message // empty' 2>/dev/null)
        echo "[ERROR] Failed to authenticate with DigitalOcean API.${msg:+ $msg}" >&2
        return 1
    fi
}

cmd_create() {
    require_token

    local name=$1
    shift

    if [ -z "$name" ]; then
        echo "[ERROR] Usage: plugin create <name> [--plan ...] [--region ...] [--image ...]" >&2
        exit 1
    fi

    # Defaults
    local plan="s-2vcpu-4gb"
    local region="nyc1"
    local image="ubuntu-24-04-x64"

    # Parse options
    while [ $# -gt 0 ]; do
        case "$1" in
            --plan)    plan="$2";    shift 2 ;;
            --region)  region="$2";  shift 2 ;;
            --image)   image="$2";   shift 2 ;;
            *)         shift ;;
        esac
    done

    # Read cloud-init template and substitute variables
    local cloud_init_file="$IVPS_PROVIDER_DIR/cloud-init.yaml"
    local user_data=""
    if [ -f "$cloud_init_file" ]; then
        # Read SSH public key for injection into the node
        local ssh_key="${SSH_PUBLIC_KEY:-}"
        if [ -z "$ssh_key" ]; then
            for keyfile in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
                if [ -f "$keyfile" ]; then
                    ssh_key=$(cat "$keyfile")
                    break
                fi
            done
        fi

        user_data=$(sed \
            -e "s|\${TS_AUTH_KEY}|${TS_AUTH_KEY:-}|g" \
            -e "s|\${NODE_HOSTNAME}|$name|g" \
            -e "s|\${IS_GATEWAY}|false|g" \
            -e "s|\${SSH_PUBLIC_KEY}|${ssh_key}|g" \
            "$cloud_init_file")
    fi

    echo "Creating droplet '$name' ($plan, $region, $image)..." >&2

    # Build the create payload
    local payload
    payload=$(jq -n \
        --arg name "$name" \
        --arg region "$region" \
        --arg size "$plan" \
        --arg image "$image" \
        --arg user_data "$user_data" \
        '{
            name: $name,
            region: $region,
            size: $size,
            image: $image,
            user_data: $user_data,
            ssh_keys: [],
            backups: false,
            ipv6: true,
            monitoring: true
        }')

    local response
    response=$(do_api POST /droplets "$payload")

    # Check for errors
    local error_msg
    error_msg=$(echo "$response" | jq -r '.message // empty')
    if [ -n "$error_msg" ]; then
        echo "[ERROR] $error_msg" >&2
        exit 1
    fi

    local droplet_id
    droplet_id=$(echo "$response" | jq -r '.droplet.id')
    if [ -z "$droplet_id" ] || [ "$droplet_id" = "null" ]; then
        echo "[ERROR] Failed to create droplet." >&2
        exit 1
    fi

    echo "Droplet $droplet_id created. Waiting for IP..." >&2

    # Poll for the droplet to get an IP (DO takes a moment to assign)
    local retries=60
    local count=0
    local ipv4="" ipv6=""
    while [ $count -lt $retries ]; do
        local detail
        detail=$(do_api GET "/droplets/$droplet_id") || true
        ipv4=$(echo "$detail" | jq -r '.droplet.networks.v4[] | select(.type=="public") | .ip_address' 2>/dev/null | head -1) || true
        ipv6=$(echo "$detail" | jq -r '.droplet.networks.v6[] | select(.type=="public") | .ip_address' 2>/dev/null | head -1) || true

        if [ -n "$ipv4" ]; then
            break
        fi
        sleep 5
        count=$((count + 1))
    done

    if [ -z "$ipv4" ]; then
        echo "[ERROR] Timed out waiting for droplet IP." >&2
        exit 1
    fi

    # Output contract for ivps
    echo "IPV4:$ipv4"
    echo "IPV6:${ipv6:-}"
    echo "PROVIDER_ID:$droplet_id"
    echo "METADATA:plan=$plan"
    echo "METADATA:region=$region"
    echo "METADATA:image=$image"
}

cmd_delete() {
    require_token

    local name=$1
    if [ -z "$name" ]; then
        echo "[ERROR] Usage: plugin delete <name>" >&2
        exit 1
    fi

    # Look up droplet by name
    local droplets
    droplets=$(do_api GET "/droplets?name=$name")
    local droplet_id
    droplet_id=$(echo "$droplets" | jq -r ".droplets[0].id // empty")

    if [ -z "$droplet_id" ]; then
        echo "[ERROR] Droplet '$name' not found." >&2
        exit 1
    fi

    echo "Destroying droplet $droplet_id ($name)..." >&2
    do_api DELETE "/droplets/$droplet_id" > /dev/null
    echo "Droplet destroyed." >&2
}

cmd_list() {
    require_token

    local droplets
    droplets=$(do_api GET "/droplets?per_page=200")
    echo "$droplets" | jq -r '.droplets[] | "\(.id)\t\(.name)\t\(.networks.v4[] | select(.type=="public") | .ip_address)\t\(.size_slug)\t\(.region.slug)\t\(.status)"' 2>/dev/null | \
        column -t -s $'\t' -N "ID,NAME,IPV4,PLAN,REGION,STATUS"
}

cmd_show() {
    require_token

    local name=$1
    if [ -z "$name" ]; then
        echo "[ERROR] Usage: plugin show <name>" >&2
        exit 1
    fi

    local droplets
    droplets=$(do_api GET "/droplets?name=$name")
    local droplet_id
    droplet_id=$(echo "$droplets" | jq -r ".droplets[0].id // empty")

    if [ -z "$droplet_id" ]; then
        echo "[ERROR] Droplet '$name' not found." >&2
        exit 1
    fi

    do_api GET "/droplets/$droplet_id" | jq '{
        id: .droplet.id,
        name: .droplet.name,
        status: .droplet.status,
        plan: .droplet.size.slug,
        region: .droplet.region.slug,
        ipv4: [.droplet.networks.v4[] | select(.type=="public") | .ip_address][0],
        ipv6: [.droplet.networks.v6[] | select(.type=="public") | .ip_address][0],
        image: .droplet.image.slug,
        created: .droplet.created_at
    }'
}

# --- DISPATCHER ---

case "${1:-}" in
    keys)     cmd_keys ;;
    validate) cmd_validate ;;
    create)   cmd_create "${@:2}" ;;
    delete)   cmd_delete "$2" ;;
    list)     cmd_list ;;
    show)     cmd_show "$2" ;;
    *)
        echo "Usage: plugin <keys|validate|create|delete|list|show> [args]"
        exit 1
        ;;
esac
